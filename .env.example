# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                  # public (frontend OK)
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # SECRETO — solo backend
SUPABASE_JWT_SECRET=                       # para validar JWTs en FastAPI

# ─── Database (vía Supabase Pooler) ──────────────────────────────
# Usar el pooler de Supabase para serverless (puerto 6543, mode=transaction)
DATABASE_URL=postgresql+psycopg://postgres.xxxxx:pwd@aws-x-region.pooler.supabase.com:6543/postgres?sslmode=require

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Twilio WhatsApp Sandbox ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_AUTH_TOKEN=xxxx             # opcional, para verificar firma

# ─── Resend ──────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@connek.ca
RESEND_FROM_NAME=Connek

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxx

# ─── Sentry ──────────────────────────────────────────────────────
SENTRY_DSN_BACKEND=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_DSN_DESKTOP=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_ENV=development

# ─── Internal ────────────────────────────────────────────────────
INTERNAL_CRON_SECRET=cambia-esto-en-prod   # HMAC para autenticar pg_net → FastAPI

# ─── Modo / Toggles ──────────────────────────────────────────────
ENV=development                            # development | preview | production
FAKE_SMS_MODE=true                         # true = no envía WhatsApp real, solo loggea
LOG_LEVEL=INFO

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=tauri://localhost,http://localhost:1420,http://localhost:5173

# ─── Frontend (Vite — solo VITE_* es expuesto al cliente) ────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=http://localhost:8000
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
